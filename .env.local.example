# =============================================================================
# McKenzie OS Environment Variables
# =============================================================================
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -- Site Lock (auth gate) --
# Set to "true" to lock the entire site behind the login gate.
# When unset or "false", the site is PUBLIC. Admin login via /gate still works.
SITE_LOCK_ENABLED=false
SITE_LOCK_ADMIN_USER=atthewm
SITE_LOCK_ADMIN_PASSWORD=your-admin-password
SITE_LOCK_GUEST_USER=guest
SITE_LOCK_GUEST_PASSWORD=your-guest-password
# Optional: a secret token that bypasses auth via ?token=<value>
SITE_LOCK_BYPASS_TOKEN=
# Cookie value used to track authenticated sessions (change to rotate sessions)
SITE_LOCK_COOKIE_VALUE=mck_gate_2026

# =============================================================================
# Supabase (Guestbook + Contact form)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# WHOOP Developer API Integration
# =============================================================================

# -- WHOOP OAuth credentials (from developer.whoop.com) --
WHOOP_CLIENT_ID=your-client-id-here
WHOOP_CLIENT_SECRET=your-client-secret-here
WHOOP_REDIRECT_URI=https://matthewrmckenzie.com/api/whoop/auth/callback

# -- Encryption key for token storage (64 hex chars = 32 bytes) --
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHOOP_ENCRYPTION_KEY=generate-a-64-hex-char-key-here

# -- Vercel KV / Upstash Redis --
# These are auto-populated when you link a KV store in the Vercel dashboard.
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your-kv-rest-api-token

# -- Public base URL (used for OAuth redirect) --
NEXT_PUBLIC_BASE_URL=https://matthewrmckenzie.com

# =============================================================================
# Notion <> Site Sync  (Nutrition, Media Library, etc.)
# =============================================================================
# Internal integration token from https://www.notion.so/my-integrations
# Share each source database with the integration in Notion (•••  -> Connections).
NOTION_TOKEN=secret_xxx

# Shared secret protecting POST /api/notion/sync (manual + cron triggers).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
NOTION_SYNC_SECRET=generate-a-random-secret

# Supabase SERVICE ROLE key (server only) — used to write/read the notion_cache
# table. Find it in Supabase -> Project Settings -> API. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Optional database id overrides (defaults baked into src/lib/notion/config.ts) --
# NOTION_DB_NUTRITION=089c0ce983db4f6abe5205d8782f8278
# NOTION_DB_FILMS=22a708535bf849109b0dc1a04a6e01a5
# NOTION_DB_TV=0d6bf30c62e74a70a8c348642555936d
# NOTION_DB_BOOKS=d9d41421a52240e68edb422f68003858
# NOTION_DB_PEOPLE=84adf0f9e8c047f1aabc44f0421d54e4
# NOTION_DB_RECIPES=8cf57959e19d4168885d92ae1c1a8e1a
